<!DOCTYPE html>
<html lang="en">
  <%- include('../includes/head', {title: 'Edit | Study of Rot'}) %>

<body>
  <%- include('../includes/header') %>

  <main>

    <h2>Edit a creator entry</h2>
    <form action="/works/<%= foundWork.slug %>" method="POST">
      <input type="text" value="<%= foundWork.name %>" name="name" placeholder="name" required /><br/>
      <input type="text" value="<%= foundWork.date %>"  name="date" placeholder="date" required /><br/>
      <input type="text" value="<%= foundWork.creator %>"  name="creator" placeholder="creator" required /><br/>
      <input type="text" value="<%= foundWork.description %>"  name="description" placeholder="description" required /><br/>
      <input type="text" value="<%= foundWork.slug %>"  name="slug" placeholder="slug" required /><br/>
      <button>Save</button>
    </form>
  </main>

</body>
</html>